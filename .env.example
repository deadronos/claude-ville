# ClaudeVille split-stack environment example.
# Copy this file to .env.local (or set these in your shell) and adjust the values
# for your collector, hubreceiver, and frontend hosts.

###############################################################################
# Collector
###############################################################################

# Base URL for the hubreceiver API that accepts collector snapshots.
# Example: http://localhost:3030
HUB_URL=http://localhost:3030

# Shared bearer token used by the collector when POSTing snapshots to the hub.
# This must match HUB_AUTH_TOKEN on the hubreceiver.
HUB_AUTH_TOKEN=dev-secret

# Optional identifier for this collector instance.
# Defaults to "collector-<hostname>" when omitted.
COLLECTOR_ID=collector-my-machine

# Optional hostname label sent with snapshots.
# Defaults to the current machine hostname when omitted.
COLLECTOR_HOST=my-machine

# How often the collector tries to flush snapshots, in milliseconds.
# Defaults to 2000.
FLUSH_INTERVAL_MS=2000

###############################################################################
# Hubreceiver
###############################################################################

# Port the hubreceiver listens on.
# Defaults to 3030.
HUB_PORT=3030

# Shared bearer token expected from collectors.
# Keep this identical to HUB_AUTH_TOKEN above.
HUB_AUTH_TOKEN=dev-secret

###############################################################################
# Frontend
###############################################################################

# Port for the static frontend server.
# Defaults to 3001.
FRONTEND_PORT=3001

# HTTP base URL for the hubreceiver that the browser app should call.
# Use the hubreceiver host/port if the frontend runs on a different machine.
# The frontend also accepts HUB_URL as an alias for this value.
# Example: http://localhost:3030
HUB_HTTP_URL=http://localhost:3030

# WebSocket URL for live updates from the hubreceiver.
# If omitted, the frontend server derives this from HUB_HTTP_URL by replacing
# http:// with ws:// and appending /ws.
# Example: ws://localhost:3030/ws
HUB_WS_URL=ws://localhost:3030/ws
